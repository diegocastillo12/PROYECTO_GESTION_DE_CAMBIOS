<%- include('partials/head') %>

<style>
/* ─── PROYECTO DETALLE ────────────────────────────────────────────────────── */
.proyecto-hero {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2rem;
  margin-bottom: 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.proyecto-hero-info h1 {
  font-size: 1.5rem; font-weight: 700; margin-bottom: 0.35rem;
}
.proyecto-hero-info p {
  color: var(--text-muted); font-size: 0.9rem; max-width: 600px; line-height: 1.6;
}
.proyecto-hero-stats {
  display: flex; gap: 1.5rem; flex-wrap: wrap; flex-shrink: 0;
}
.hero-stat {
  text-align: center;
  background: var(--bg-secondary);
  border-radius: 12px;
  padding: 0.75rem 1.25rem;
  min-width: 90px;
}
.hero-stat-val { font-size: 1.75rem; font-weight: 800; color: var(--accent); }
.hero-stat-lbl { font-size: 0.73rem; color: var(--text-muted); margin-top: 0.15rem; }

/* Barra de avance general */
.avance-general {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.25rem 1.5rem;
  margin-bottom: 1.5rem;
  display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;
}
.avance-label { font-size: 0.9rem; color: var(--text-muted); flex-shrink: 0; }
.avance-bar-outer {
  flex: 1; min-width: 200px; background: var(--bg-secondary);
  border-radius: 99px; height: 12px; overflow: hidden;
}
.avance-bar-inner {
  height: 100%; border-radius: 99px;
  background: linear-gradient(90deg, var(--accent), #7c3aed);
  transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
}
.avance-pct { font-size: 1.2rem; font-weight: 700; color: var(--accent); flex-shrink: 0; }

/* Tabs */
.tabs { display: flex; gap: 0.25rem; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem; }
.tab-btn {
  padding: 0.65rem 1.1rem; border: none; background: none;
  color: var(--text-muted); cursor: pointer; border-radius: 8px 8px 0 0;
  font-size: 0.9rem; font-weight: 500; transition: all 0.2s;
  border-bottom: 2px solid transparent; margin-bottom: -1px;
}
.tab-btn:hover  { color: var(--text-primary); background: var(--bg-secondary); }
.tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); background: rgba(99,102,241,0.06); }
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* Cronograma tabla */
.cronograma-table { width: 100%; border-collapse: collapse; }
.cronograma-table th, .cronograma-table td {
  padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border);
  font-size: 0.875rem;
}
.cronograma-table th { color: var(--text-muted); font-weight: 500; text-transform: uppercase; font-size: 0.75rem; }
.cronograma-table tr:hover td { background: var(--bg-hover, rgba(99,102,241,0.04)); }

/* Progress cells */
.progress-mini-outer {
  background: var(--bg-secondary); border-radius: 99px; height: 6px;
  min-width: 80px; overflow: hidden; display: inline-block; width: 100px;
}
.progress-mini-inner {
  height: 100%; border-radius: 99px;
  background: linear-gradient(90deg, var(--accent), #7c3aed);
}

/* Equipo grid */
.equipo-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem;
}
.miembro-card {
  background: var(--bg-secondary); border: 1px solid var(--border);
  border-radius: 12px; padding: 1.25rem; text-align: center;
}
.miembro-avatar {
  width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #7c3aed);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; font-weight: 700; color: white;
  margin: 0 auto 0.75rem;
}
.miembro-nombre { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.25rem; }
.miembro-rol { font-size: 0.78rem; color: var(--text-muted); }

/* Ranking */
.ranking-item {
  display: flex; align-items: center; gap: 1rem;
  padding: 0.75rem 1rem; border-radius: 10px;
  background: var(--bg-secondary); margin-bottom: 0.5rem;
  transition: background 0.2s;
}
.ranking-item:hover { background: var(--border); }
.ranking-pos { font-size: 1.25rem; width: 2rem; text-align: center; flex-shrink: 0; }
.ranking-info { flex: 1; }
.ranking-nombre { font-weight: 600; font-size: 0.9rem; }
.ranking-rol { font-size: 0.78rem; color: var(--text-muted); }
.ranking-pct { font-weight: 700; color: var(--accent); font-size: 1.05rem; flex-shrink: 0; }

/* Reporte button */
.btn-reporte {
  background: linear-gradient(135deg, var(--accent), #7c3aed);
  color: white; border: none; border-radius: 8px;
  padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 600;
  cursor: pointer; transition: opacity 0.2s;
}
.btn-reporte:hover { opacity: 0.85; }

/* ─── MODAL OVERLAY ──────────────────────────────────────────────────────── */
.modal-overlay {
  display: none; position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.72);
  backdrop-filter: blur(6px);
  align-items: center; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal-box {
  background: var(--bg-primary);
  border: 1px solid var(--border-default);
  border-radius: 16px;
  box-shadow: 0 32px 100px rgba(0,0,0,0.5);
  animation: slideUp 0.22s ease;
  color: var(--text-primary);
}
[data-theme="light"] .modal-box {
  background: #ffffff;
  border-color: #d1d5db;
  box-shadow: 0 32px 100px rgba(0,0,0,0.18);
}
@keyframes slideUp {
  from { transform: translateY(24px); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Estilos de Markdown para el análisis con IA */
#ia-contenido h1, #ia-contenido h2, #ia-contenido h3 {
  color: var(--text-primary);
  margin-top: 1.25rem;
  margin-bottom: 0.6rem;
  font-weight: 700;
}
#ia-contenido h1 { font-size: 1.2rem; border-bottom: 1px solid var(--border-subtle); padding-bottom: 0.3rem; margin-top: 1.5rem; }
#ia-contenido h2 { font-size: 1.05rem; }
#ia-contenido h3 { font-size: 0.95rem; }
#ia-contenido p { margin-bottom: 0.75rem; color: var(--text-secondary); line-height: 1.55; }
#ia-contenido ul, #ia-contenido ol { margin-left: 1.5rem; margin-bottom: 0.85rem; color: var(--text-secondary); }
#ia-contenido li { margin-bottom: 0.35rem; }
#ia-contenido strong { color: var(--text-primary); }
#ia-contenido blockquote {
  border-left: 4px solid var(--accent);
  background: var(--bg-secondary);
  padding: 0.6rem 1.1rem;
  margin: 1rem 0;
  border-radius: 6px;
  opacity: 0.95;
}
[data-theme="light"] #ia-contenido blockquote {
  background: #f3f4f6;
  border-left-color: #4f46e5;
}
.modal-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.25rem; color: var(--text-primary); }
.modal-close {
  float: right; background: none; border: none; cursor: pointer;
  color: var(--text-muted); font-size: 1.25rem; line-height: 1;
  padding: 0.15rem 0.35rem; border-radius: 6px;
  transition: background 0.15s;
}
.modal-close:hover { background: var(--bg-hover); color: var(--text-primary); }

/* ─── TABS DEL MODAL ─────────────────────────────────────────────────────── */
#modalVersiones .tab-btn {
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text-muted);
  padding: 0.5rem 1rem;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  border-radius: 8px 8px 0 0;
  transition: all 0.15s;
  margin-bottom: -1px;
}
#modalVersiones .tab-btn:hover  { color: var(--text-primary); background: var(--bg-hover); }
#modalVersiones .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); background: var(--accent-subtle); }

/* ─── TABLA DEL HISTORIAL ────────────────────────────────────────────────── */
#versiones-tabla-body tr:hover { background: var(--bg-hover); }
#versiones-tabla-body tr { transition: background 0.15s; }

/* ─── VISOR COMPARADOR ───────────────────────────────────────────────────── */
#vtab-comparar {
  flex: 1; display: none; flex-direction: column; min-height: 0; overflow: hidden;
}
#comparar-visor {
  flex: 1; display: none; flex-direction: column; gap: 0.6rem; min-height: 0; overflow: hidden;
}
#panel-sidebyside {
  flex: 1; min-height: 0; overflow: hidden;
}
#panel-sidebyside > div { min-height: 0; overflow: hidden; }
#visor-v1, #visor-v2 { flex: 1; min-height: 0; overflow: auto; }
#visor-v1 iframe, #visor-v2 iframe {
  width: 100%; height: 100%; min-height: 580px; border: none; display: block;
}

/* Cabecera de versión antigua/nueva */
#comparar-header-v1 {
  background: rgba(248,81,73,0.08);
  border: 1px solid rgba(248,81,73,0.3);
  border-radius: 8px; padding: 0.5rem 0.85rem;
  font-size: 0.8rem; font-weight: 600; color: #f85149;
}
#comparar-header-v2 {
  background: rgba(46,164,79,0.08);
  border: 1px solid rgba(46,164,79,0.3);
  border-radius: 8px; padding: 0.5rem 0.85rem;
  font-size: 0.8rem; font-weight: 600; color: #2ea44f;
}
[data-theme="light"] #comparar-header-v1 { background: rgba(220,38,38,0.06); border-color: rgba(220,38,38,0.25); color: #dc2626; }
[data-theme="light"] #comparar-header-v2 { background: rgba(5,150,105,0.06); border-color: rgba(5,150,105,0.25); color: #059669; }

/* Paneles laterales */
#panel-sidebyside > div {
  border-radius: 10px; overflow: hidden;
  display: flex; flex-direction: column;
}
.visor-panel-label-antigua {
  background: rgba(248,81,73,0.08); padding: 0.4rem 0.75rem;
  font-size: 0.72rem; font-weight: 700; color: #f85149; flex-shrink: 0;
}
.visor-panel-label-nueva {
  background: rgba(46,164,79,0.08); padding: 0.4rem 0.75rem;
  font-size: 0.72rem; font-weight: 700; color: #2ea44f; flex-shrink: 0;
}
[data-theme="light"] .visor-panel-label-antigua { background: rgba(220,38,38,0.06); color: #dc2626; }
[data-theme="light"] .visor-panel-label-nueva   { background: rgba(5,150,105,0.06); color: #059669; }

/* Panel diff */
#panel-diff {
  display: none; flex: 1; overflow: auto;
  background: var(--bg-tertiary);
  border-radius: 10px; border: 1px solid var(--border-subtle);
  padding: 0.75rem; font-family: monospace; font-size: 0.78rem;
  min-height: 500px; height: 100%;
}
[data-theme="light"] #panel-diff { background: #f8fafc; border-color: #e2e8f0; }

/* Botones de vista */
#vbtn-sidebyside, #vbtn-diff {
  font-size: 0.75rem; padding: 0.3rem 0.75rem;
  border-radius: 6px; cursor: pointer;
  background: var(--bg-secondary);
  border: 1px solid var(--border-default);
  color: var(--text-secondary);
  transition: all 0.15s;
}
#vbtn-sidebyside:hover, #vbtn-diff:hover { background: var(--bg-hover); color: var(--text-primary); }

/* Controles de formulario (Inputs/Textareas) — modo claro */
[data-theme="light"] .form-control {
  background: #ffffff;
  border-color: #d1d5db;
  color: #111827;
}
[data-theme="light"] .form-control:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.15);
  outline: none;
}

/* Contenido Word/Excel en modo claro */
[data-theme="light"] #visor-v1,
[data-theme="light"] #visor-v2 { background: #ffffff; }
[data-theme="light"] #visor-v1 div,
[data-theme="light"] #visor-v2 div { color: #111827; }


/* Árbol metodología */
.metodologia-tree { padding: 0; }
.etapa-item {
  background: var(--bg-secondary); border-radius: 10px;
  margin-bottom: 0.75rem; overflow: hidden;
}
.etapa-header {
  padding: 0.85rem 1.1rem; font-weight: 600; font-size: 0.9rem;
  cursor: pointer; display: flex; align-items: center; gap: 0.5rem;
  user-select: none;
}
.etapa-header:hover { background: var(--border); }
.etapa-body { padding: 0.5rem 1.1rem 0.85rem 2.5rem; border-top: 1px solid var(--border); display: none; }
.etapa-body.open { display: block; }
.fase-item { margin-bottom: 0.6rem; }
.fase-nombre { font-size: 0.85rem; font-weight: 500; color: var(--text-primary); margin-bottom: 0.3rem; }
.ecm-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.ecm-chip {
  background: rgba(99,102,241,0.12); color: var(--accent);
  border-radius: 99px; padding: 0.2rem 0.6rem; font-size: 0.72rem; font-weight: 500;
}


</style>

<div class="app-wrapper">
  <%- include('partials/sidebar') %>

  <main class="main-content">

    <!-- Hero del proyecto -->
    <div class="proyecto-hero">
      <div class="proyecto-hero-info">
        <h1>📁 <%= proyecto.nombre %></h1>
        <p><%= proyecto.descripcion || 'Sin descripción adicional.' %></p>
        <div style="margin-top:0.75rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
          <% const estadoClass2 = {Activo:'badge-teal',Pausado:'badge-orange',Cerrado:'badge-slate',Archivado:'badge-slate'}[proyecto.estado] || 'badge-slate'; %>
          <span class="badge <%= estadoClass2 %>"><%= proyecto.estado %></span>
          <% if(proyecto.metodologia_nombre) { %><span class="badge badge-blue">📐 <%= proyecto.metodologia_nombre %></span><% } %>
          <% if(proyecto.fecha_inicio) { %><span class="badge badge-slate">📅 <%= new Date(proyecto.fecha_inicio).toLocaleDateString('es-PE') %></span><% } %>
          <% if(proyecto.fecha_fin) { %><span class="badge badge-slate">🏁 <%= new Date(proyecto.fecha_fin).toLocaleDateString('es-PE') %></span><% } %>
          <% if(proyecto.github_repo) { %>
          <a href="https://github.com/<%= proyecto.github_repo %>" target="_blank" class="badge badge-teal" style="display:inline-flex; align-items:center; gap:0.25rem; background:#0d9488; color:white; text-decoration:none;" title="Ver repositorio en GitHub">
            🐙 <%= proyecto.github_repo %>
          </a>
          <% } %>
        </div>
      </div>
      <div class="proyecto-hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-val"><%= resumen.total || 0 %></div>
          <div class="hero-stat-lbl">Actividades</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-val"><%= resumen.completadas || 0 %></div>
          <div class="hero-stat-lbl">Completadas</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-val"><%= tickets.length %></div>
          <div class="hero-stat-lbl">Tickets</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-val"><%= equipo.length %></div>
          <div class="hero-stat-lbl">Equipo</div>
        </div>
      </div>
    </div>

    <!-- Barra de avance general -->
    <div class="avance-general">
      <span class="avance-label">📊 Avance General del Proyecto:</span>
      <div class="avance-bar-outer">
        <div class="avance-bar-inner" style="width:<%= resumen.promedio || promedioAvance %>%"></div>
      </div>
      <span class="avance-pct"><%= parseFloat(resumen.promedio || promedioAvance || 0).toFixed(1) %>%</span>
    </div>

    <!-- Tabs -->
    <div class="tabs">
      <button id="btn-tab-cronograma" class="tab-btn active" onclick="switchTab('cronograma', this)">📅 Cronograma</button>
      <button id="btn-tab-equipo" class="tab-btn" onclick="switchTab('equipo', this)">👥 Equipo</button>
      <button id="btn-tab-metodologia" class="tab-btn" onclick="switchTab('metodologia', this)">📐 Metodología</button>
      <button id="btn-tab-tickets" class="tab-btn" onclick="switchTab('tickets', this)">🎫 Tickets</button>
      <% if (user.rol !== 'Solicitante') { %>
      <button id="btn-tab-ranking" class="tab-btn" onclick="switchTab('ranking', this)">🏆 Ranking</button>
      <% } %>
    </div>

    <!-- TAB: CRONOGRAMA -->
    <div id="tab-cronograma" class="tab-panel active">
      <div class="card" style="overflow:auto;">
        <div class="section-header" style="margin-bottom:1rem;">
          <h2 class="section-title" style="font-size:1rem;">Actividades del Cronograma</h2>
        </div>
        <% if(cronograma && cronograma.length > 0) { %>

        <!-- DIAGRAMA DE GANTT -->
        <%
          // Rango de fechas
          let minDate = null;
          let maxDate = null;
          cronograma.forEach(a => {
            const s = new Date(a.fecha_inicio);
            const f = new Date(a.fecha_fin);
            if (!minDate || s < minDate) minDate = s;
            if (!maxDate || f > maxDate) maxDate = f;
          });

          if (!minDate && proyecto.fecha_inicio) minDate = new Date(proyecto.fecha_inicio);
          if (!maxDate && proyecto.fecha_fin) maxDate = new Date(proyecto.fecha_fin);
          if (!minDate) minDate = new Date();
          if (!maxDate) maxDate = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000);

          if (minDate.getTime() === maxDate.getTime()) {
            maxDate = new Date(minDate.getTime() + 7 * 24 * 60 * 60 * 1000);
          }

          const totalTime = maxDate.getTime() - minDate.getTime();

          // Intervalos para labels
          const intervals = 4;
          const labels = [];
          for (let i = 0; i <= intervals; i++) {
            const dateVal = new Date(minDate.getTime() + (totalTime / intervals) * i);
            labels.push(dateVal.toLocaleDateString('es-PE', { day: '2-digit', month: '2-digit' }));
          }
        %>
        <div style="margin: 0 0 1.5rem 0; padding: 1rem; background: var(--bg-secondary); border-radius: var(--radius-md); border: 1px solid var(--border-subtle); overflow-x: auto;">
          <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.85rem; display: flex; align-items: center; gap: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">
            📊 Línea de Tiempo Visual (Gantt)
          </h4>
          
          <!-- Escala de fechas -->
          <div style="display: flex; align-items: center; gap: 1rem; font-size: 0.68rem; color: var(--text-muted); margin-bottom: 0.75rem; border-bottom: 1px solid var(--border-subtle); padding-bottom: 0.4rem; min-width: 500px;">
            <div style="width: 180px; font-weight: 700; flex-shrink: 0;">Actividad</div>
            <div style="flex: 1; display: flex; justify-content: space-between; position: relative; padding: 0 4px;">
              <% labels.forEach(lbl => { %>
              <span>📅 <%= lbl %></span>
              <% }) %>
            </div>
          </div>

          <!-- Listado de barras -->
          <div style="display: flex; flex-direction: column; gap: 0.6rem; min-width: 500px;">
            <% cronograma.forEach(a => {
              const actStart = new Date(a.fecha_inicio);
              const actEnd = new Date(a.fecha_fin);
              
              const startVal = Math.max(minDate.getTime(), actStart.getTime());
              const endVal = Math.min(maxDate.getTime(), actEnd.getTime());
              
              const leftOffset = ((startVal - minDate.getTime()) / totalTime) * 100;
              const widthPct = Math.max(4, ((endVal - startVal) / totalTime) * 100);

              let colorBg = 'rgba(100, 116, 139, 0.15)';
              let colorBorder = '#64748b';
              let colorProgress = '#64748b';
              if (a.estado === 'Completado') {
                colorBg = 'rgba(16, 185, 129, 0.12)';
                colorBorder = '#10b981';
                colorProgress = '#10b981';
              } else if (a.estado === 'En Progreso') {
                colorBg = 'rgba(59, 130, 246, 0.12)';
                colorBorder = '#3b82f6';
                colorProgress = '#3b82f6';
              } else if (a.estado === 'Bloqueado') {
                colorBg = 'rgba(239, 68, 68, 0.12)';
                colorBorder = '#ef4444';
                colorProgress = '#ef4444';
              }
            %>
            <div style="display: flex; align-items: center; gap: 1rem; font-size: 0.72rem;">
              <div style="width: 180px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-secondary); flex-shrink: 0;" title="<%= a.nombre %>">
                <%= a.nombre %>
              </div>
              <div style="flex: 1; background: var(--bg-tertiary); height: 16px; border-radius: 4px; position: relative; border: 1px solid var(--border-subtle); overflow: hidden;">
                <!-- Gantt Bar -->
                <div style="position: absolute; left: <%= leftOffset %>%; width: <%= widthPct %>%; height: 100%; background: <%= colorBg %>; border-left: 3px solid <%= colorBorder %>; display: flex; align-items: center;">
                  <!-- Inner progress fill -->
                  <div style="width: <%= a.porcentaje_avance %>%; height: 100%; background: <%= colorProgress %>; opacity: 0.18;"></div>
                  <!-- Label inside the row -->
                  <span style="position: absolute; left: 8px; font-size: 0.6rem; font-weight: 700; color: var(--text-primary); white-space: nowrap; pointer-events: none;">
                    <%= parseFloat(a.porcentaje_avance).toFixed(0) %>% · <%= a.asignado_nombre || 'Sin asignar' %>
                  </span>
                </div>
              </div>
            </div>
            <% }) %>
          </div>

        </div>

        <table class="cronograma-table">
          <thead>
            <tr>
              <th>Actividad</th>
              <th>Fase</th>
              <th>Responsable</th>
              <th>Inicio</th>
              <th>Fin</th>
              <th>Avance</th>
              <th>Estado</th>
              <th>Entregable</th>
              <% if(user.rol !== 'Solicitante'){ %><th>Acción</th><% } %>
            </tr>
          </thead>
          <tbody>
          <% cronograma.forEach(act => {
            const estadoColores = {
              Pendiente: 'badge-slate', 'En Progreso': 'badge-orange',
              Completado: 'badge-teal', Bloqueado: 'badge-red'
            };
          %>
            <tr>
              <td>
                <div style="font-weight:500;"><%= act.nombre %></div>
                <% if(act.descripcion) { %><div style="font-size:0.78rem;color:var(--text-muted);"><%= act.descripcion %></div><% } %>
              </td>
              <td style="color:var(--text-muted);font-size:0.8rem;">
                <% if(act.etapa_nombre) { %><div style="font-size:0.7rem;color:var(--text-muted);"><%= act.etapa_nombre %></div><% } %>
                <%= act.fase_nombre || '—' %>
              </td>
              <td style="font-size:0.82rem;">
                <% if(act.asignado_nombre) { %>
                <div style="display:flex;align-items:center;gap:0.35rem;">
                  <div style="width:26px;height:26px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;color:white;flex-shrink:0;">
                    <%= act.asignado_nombre.slice(0,2).toUpperCase() %>
                  </div>
                  <span style="font-size:0.8rem;"><%= act.asignado_nombre.split(' ')[0] %></span>
                </div>
                <% } else { %>
                <span style="color:var(--text-muted);">Sin asignar</span>
                <% } %>
              </td>
              <td style="font-size:0.82rem;"><%= act.fecha_inicio ? new Date(act.fecha_inicio).toLocaleDateString('es-PE') : '—' %></td>
              <td style="font-size:0.82rem;"><%= act.fecha_fin ? new Date(act.fecha_fin).toLocaleDateString('es-PE') : '—' %></td>
              <td>
                <div style="display:flex;align-items:center;gap:0.5rem;">
                  <div class="progress-mini-outer"><div class="progress-mini-inner" style="width:<%= act.porcentaje_avance %>%"></div></div>
                  <span style="font-size:0.8rem;font-weight:600;"><%= parseFloat(act.porcentaje_avance||0).toFixed(0) %>%</span>
                </div>
              </td>
              <td><span class="badge <%= estadoColores[act.estado] || 'badge-slate' %>"><%= act.estado %></span></td>
              <td style="font-size:0.8rem;">
                <% if(act.entregable_ticket_id) { %>
                  <a href="/tickets/<%= act.entregable_ticket_id %>" style="color:var(--accent);text-decoration:none;font-weight:500;">
                    <%= act.entregable_ticket_id %>
                  </a>
                <% } else { %>—<% } %>
              </td>
              <% if(user.rol !== 'Solicitante'){ %>
              <td>
                <div style="display:flex; gap:0.4rem; align-items:center;">
                  <% 
                    const puedeReportar = act.es_reportable && (
                      user.id === act.id_usuario ||
                      user.rol === 'Administrador' ||
                      miRolEnProyecto === 'Líder Técnico'
                    );
                  %>
                  <% if(puedeReportar) { %>
                  <button class="btn-reporte" onclick="abrirModalReporte(<%= act.id_actividad %>, '<%= act.nombre.replace(/'/g, "\\'") %>', <%= act.porcentaje_avance %>)" style="padding: 0.35rem 0.6rem; font-size: 0.75rem;">
                    📝 Reportar
                  </button>
                  <% } %>

                  <button class="btn-reporte" onclick="abrirModalVersiones(<%= act.id_actividad %>, '<%= act.nombre.replace(/'/g, "\\'") %>', <%= puedeReportar ? 'true' : 'false' %>)" style="padding: 0.35rem 0.6rem; font-size: 0.75rem; background: var(--bg-hover, #2d3748); border: 1px solid var(--border-subtle, #4a5568); color: var(--text-secondary, #e2e8f0);">
                    🗂️ Versiones
                  </button>
                </div>
              </td>
              <% } %>
            </tr>
          <% }); %>
          </tbody>
        </table>
        <% } else { %>
        <div style="text-align:center;padding:3rem;color:var(--text-muted);">
          <div style="font-size:2.5rem;margin-bottom:0.75rem;">📅</div>
          <p>No hay actividades en el cronograma.</p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- TAB: EQUIPO -->
    <div id="tab-equipo" class="tab-panel">
      <div class="card">
        <h2 class="section-title" style="font-size:1rem;margin-bottom:1.25rem;">👥 Equipo del Proyecto</h2>
        <% if(equipo && equipo.length > 0) { %>
        <div class="equipo-grid">
          <% equipo.forEach(m => { %>
          <div class="miembro-card">
            <div class="miembro-avatar"><%= m.nombre.slice(0,2).toUpperCase() %></div>
            <div class="miembro-nombre"><%= m.nombre %></div>
            <div class="miembro-rol"><%= m.rol_en_proyecto %></div>
            <div style="font-size:0.72rem;color:var(--text-muted);margin-top:0.3rem;"><%= m.correo %></div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <p style="color:var(--text-muted);">No hay miembros asignados.</p>
        <% } %>
      </div>
    </div>

    <!-- TAB: METODOLOGÍA -->
    <div id="tab-metodologia" class="tab-panel">
      <div class="card">
        <h2 class="section-title" style="font-size:1rem;margin-bottom:1.25rem;">📐 Metodología del Proyecto</h2>
        <% if(arbolMetodologia) { %>
        <div style="margin-bottom:1rem;">
          <strong style="font-size:1.1rem;"><%= arbolMetodologia.nombre %></strong>
          <% if(arbolMetodologia.descripcion) { %>
          <p style="color:var(--text-muted);font-size:0.85rem;margin-top:0.35rem;"><%= arbolMetodologia.descripcion %></p>
          <% } %>
        </div>
        <div class="metodologia-tree">
          <% (arbolMetodologia.etapas || []).forEach((etapa, ei) => { %>
          <div class="etapa-item">
            <div class="etapa-header" onclick="toggleEtapa(this)">
              <span>▶</span>
              <span>Etapa <%= ei+1 %>: <%= etapa.nombre %></span>
              <span style="margin-left:auto;font-size:0.75rem;color:var(--text-muted);"><%= (etapa.fases||[]).length %> fases</span>
            </div>
            <div class="etapa-body">
              <% (etapa.fases || []).forEach(fase => { %>
              <div class="fase-item">
                <div class="fase-nombre">🗂 <%= fase.nombre %></div>
                <div class="ecm-chips">
                  <% (fase.ecm || []).forEach(ecm => { %>
                  <span class="ecm-chip" title="<%= ecm.tipo %>"><%= ecm.nombre %></span>
                  <% }); %>
                  <% if(!fase.ecm || !fase.ecm.length) { %><span style="font-size:0.75rem;color:var(--text-muted);">Sin elementos</span><% } %>
                </div>
              </div>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <div style="text-align:center;padding:3rem;color:var(--text-muted);">
          <div style="font-size:2.5rem;margin-bottom:0.75rem;">📐</div>
          <p>No hay metodología configurada para este proyecto.</p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- TAB: TICKETS -->
    <div id="tab-tickets" class="tab-panel">
      <div class="card" style="overflow:auto;">
        <div class="section-header" style="margin-bottom:1rem;">
          <h2 class="section-title" style="font-size:1rem;">🎫 Solicitudes de Cambio del Proyecto</h2>
          <% if(['Solicitante', 'Director', 'Gestor de Configuración', 'Líder Técnico'].includes(miRolEnProyecto) || ['Solicitante', 'Director', 'Gestor de Configuración', 'Líder Técnico'].includes(user.rol) || user.rol === 'Administrador'){ %>
          <a href="/tickets/nuevo?id_proyecto=<%= proyecto.id_proyecto %>" class="btn btn-primary" style="font-size:0.82rem;padding:0.4rem 1rem;">➕ Nueva Solicitud</a>
          <% } %>
        </div>
        <% if(tickets && tickets.length > 0) { %>
        <table class="cronograma-table">
          <thead><tr><th>ID</th><th>Título</th><th>Estado</th><th>Solicitante</th><th>Fecha</th><th></th></tr></thead>
          <tbody>
          <% tickets.forEach(t => {
            const estadoMeta2 = {
              'Solicitado':'badge-slate','En Análisis':'badge-orange',
              'Pendiente de Aprobación':'badge-blue','Aprobado':'badge-teal',
              'En Desarrollo':'badge-yellow','En Pruebas QA':'badge-pink',
              'En Pruebas UAT':'badge-purple','Listo para Integración':'badge-blue',
              'Liberado':'badge-green','Rechazado':'badge-red','Descartado':'badge-slate'
            };
          %>
          <tr>
            <td><code style="font-size:0.78rem;"><%= t.ticket_id || t.id %></code></td>
            <td><%= t.titulo %></td>
            <td><span class="badge <%= estadoMeta2[t.estado]||'badge-slate' %>"><%= t.estado %></span></td>
            <td style="font-size:0.82rem;"><%= t.solicitanteNombre || '—' %></td>
            <td style="font-size:0.78rem;color:var(--text-muted);"><%= t.fechaCreacion ? new Date(t.fechaCreacion).toLocaleDateString('es-PE') : '—' %></td>
            <td><a href="/tickets/<%= t.ticket_id || t.id %>" class="btn btn-ghost" style="font-size:0.78rem;padding:0.3rem 0.75rem;">Ver</a></td>
          </tr>
          <% }); %>
          </tbody>
        </table>
        <% } else { %>
        <div style="text-align:center;padding:3rem;color:var(--text-muted);">
          <div style="font-size:2.5rem;margin-bottom:0.75rem;">🎫</div>
          <p>No hay tickets en este proyecto.</p>
        </div>
        <% } %>
      </div>
    </div>

    <% if (user.rol !== 'Solicitante') { %>
    <!-- TAB: RANKING -->
    <div id="tab-ranking" class="tab-panel">
      <div class="card">
        <h2 class="section-title" style="font-size:1rem;margin-bottom:1.25rem;">🏆 Ranking de Avance del Equipo</h2>
        <% if(ranking && ranking.length > 0) { %>
        <% const medallas = ['🥇','🥈','🥉']; %>
        <% ranking.forEach((m, i) => { %>
        <div class="ranking-item">
          <div class="ranking-pos"><%= medallas[i] || (i+1) %></div>
          <div class="ranking-info">
            <div class="ranking-nombre"><%= m.nombre %></div>
            <div class="ranking-rol"><%= m.rol %> · <%= m.total_reportes %> reportes</div>
          </div>
          <div style="flex:1;margin:0 1rem;">
            <div class="progress-mini-outer" style="width:100%;display:block;">
              <div class="progress-mini-inner" style="width:<%= m.promedio_avance || 0 %>%;height:8px;"></div>
            </div>
          </div>
          <div class="ranking-pct"><%= parseFloat(m.promedio_avance||0).toFixed(1) %>%</div>
        </div>
        <% }); %>
        <% } else { %>
        <div style="text-align:center;padding:3rem;color:var(--text-muted);">
          <div style="font-size:2.5rem;margin-bottom:0.75rem;">🏆</div>
          <p>No hay reportes de avance aún.</p>
        </div>
        <% } %>

        <!-- Últimos reportes -->
        <% if(reportes && reportes.length > 0) { %>
        <h3 style="font-size:0.9rem;font-weight:600;margin:1.5rem 0 0.75rem;color:var(--text-muted);">📋 Últimos Reportes de Avance</h3>
        <% reportes.slice(0,8).forEach(r => { %>
        <div style="display:flex;gap:1rem;align-items:center;padding:0.6rem 0;border-bottom:1px solid var(--border);">
          <div style="flex:1;">
            <span style="font-weight:500;font-size:0.85rem;"><%= r.reportado_por %></span>
            <span style="color:var(--text-muted);font-size:0.78rem;"> en <em><%= r.actividad_nombre %></em></span>
          </div>
          <span style="font-weight:700;color:var(--accent);">+<%= r.porcentaje %>%</span>
          <span style="font-size:0.75rem;color:var(--text-muted);">
            <%= new Date(r.fecha_reporte).toLocaleDateString('es-PE', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %>
          </span>
          <% if(!r.visto_por_cliente && user.rol === 'Solicitante') { %>
          <span class="badge badge-orange" style="font-size:0.65rem;">Nuevo</span>
          <% } %>
        </div>
        <% }); %>
        <% } %>
      </div>
    </div>
    <% } %>

  </main>
</div>

<!-- Modal: Reportar Avance -->
<div class="modal-overlay" id="modalReporte">
  <div class="modal-box" style="width: 480px; max-width: 90vw; padding: 1.75rem; display: flex; flex-direction: column; gap: 0.85rem;">
    <button class="modal-close" onclick="cerrarModal('modalReporte')">✕</button>
    <div class="modal-title">📝 Reportar Avance</div>
    <p id="modal-actividad-nombre" style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.25rem;"></p>

    <div class="form-group">
      <label class="form-label">Porcentaje de Avance (%)</label>
      <input type="range" id="avance-slider" min="0" max="100" step="1" value="0"
        oninput="document.getElementById('avance-val').textContent = this.value + '%'"
        style="width:100%;margin-bottom:0.5rem;accent-color:var(--accent);">
      <div style="text-align:center;font-size:1.5rem;font-weight:700;color:var(--accent);" id="avance-val">0%</div>
    </div>

    <div class="form-group">
      <label class="form-label">Comentario (opcional)</label>
      <textarea id="reporte-comentario" class="form-control" rows="3" style="resize:vertical;" placeholder="Describe el avance realizado..."></textarea>
    </div>

    <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1.25rem;">
      <button class="btn btn-ghost" onclick="cerrarModal('modalReporte')">Cancelar</button>
      <button class="btn btn-primary" id="btn-enviar-reporte" onclick="enviarReporte()">Enviar Reporte</button>
    </div>
  </div>
</div>

<!-- Modal: Versiones de ECS -->
<div class="modal-overlay" id="modalVersiones">
  <div class="modal-box" id="modalVersiones-box" style="width: 98vw; max-width: 1600px; max-height: 96vh; display: flex; flex-direction: column; overflow: hidden; padding: 1.25rem;">
    <button class="modal-close" onclick="cerrarModal('modalVersiones')">✕</button>
    <div class="modal-title" style="margin-bottom: 0.25rem;">🗂️ Versiones del ECS</div>
    <p id="modal-versiones-actividad-nombre" style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1rem; font-weight: 500;"></p>

    <!-- TABS internos del modal -->
    <div style="display:flex; gap:0.25rem; border-bottom:1px solid var(--border); margin-bottom:1rem;">
      <button id="vtab-btn-historial" class="tab-btn active" onclick="switchVTab('historial')" style="font-size:0.8rem; padding:0.45rem 0.9rem;">📋 Historial</button>
      <button id="vtab-btn-comparar"  class="tab-btn"        onclick="switchVTab('comparar')"  style="font-size:0.8rem; padding:0.45rem 0.9rem;">🔍 Comparar Versiones</button>
      <button id="vtab-btn-subir"     class="tab-btn"        onclick="switchVTab('subir')"     style="font-size:0.8rem; padding:0.45rem 0.9rem;" id="vtab-btn-subir-real">⬆️ Subir Versión</button>
    </div>

    <!-- TAB: Historial -->
    <div id="vtab-historial" style="flex:1; overflow-y:auto; min-height:0;">
      <table class="cronograma-table" style="font-size: 0.82rem; width: 100%;">
        <thead>
          <tr style="border-bottom: 1px solid var(--border-subtle);">
            <th style="padding:0.5rem 0.4rem; width:35px; text-align:center;">
              <input type="checkbox" id="check-all-versions" onchange="toggleAllVersionCheckboxes(this)" title="Seleccionar todos">
            </th>
            <th style="padding:0.5rem 0.4rem; width:90px;">Versión</th>
            <th style="padding:0.5rem 0.4rem;">Descripción del Cambio</th>
            <th style="padding:0.5rem 0.4rem; width:110px;">Autor</th>
            <th style="padding:0.5rem 0.4rem; width:120px;">Fecha</th>
            <th style="padding:0.5rem 0.4rem; width:80px;">Tipo</th>
            <th style="padding:0.5rem 0.4rem; width:80px; text-align:right;">Acción</th>
          </tr>
        </thead>
        <tbody id="versiones-tabla-body"></tbody>
      </table>
      <div id="versiones-vacio" style="text-align:center; padding:2.5rem; color:var(--text-muted); display:none;">
        <span style="font-size:2.5rem;">📂</span>
        <p style="margin-top:0.5rem; font-size:0.85rem;">No hay versiones registradas para este elemento de configuración.</p>
      </div>
      <div style="margin-top:0.75rem; display:flex; justify-content:flex-end;">
        <button class="btn btn-primary" onclick="switchVTab('comparar')" style="font-size:0.78rem; padding:0.4rem 1rem;">
          🔍 Comparar seleccionados
        </button>
      </div>
    </div>

    <!-- TAB: Comparar -->
    <div id="vtab-comparar" style="display:none; flex:1; overflow:hidden; flex-direction:column; min-height:0;">
      <div id="comparar-seleccion-msg" style="text-align:center; padding:2rem; color:var(--text-muted);">
        <div style="font-size:2rem; margin-bottom:0.5rem;">☑️</div>
        <p style="font-size:0.85rem;">Selecciona exactamente <strong>2 versiones</strong> en el Historial y vuelve aquí para comparar.</p>
      </div>

      <!-- Visor lado a lado -->
      <div id="comparar-visor" style="display:none; flex:1; overflow:hidden; flex-direction:column; gap:0.75rem; min-height:0;">
        <div style="display:flex; align-items:center; gap:1rem; flex-shrink:0; flex-wrap:wrap;">
          <div id="comparar-header-v1" style="flex:1; background:rgba(248,81,73,0.1); border:1px solid rgba(248,81,73,0.3); border-radius:8px; padding:0.5rem 0.85rem; font-size:0.8rem; font-weight:600;"></div>
          <div style="font-size:1.2rem; color:var(--text-muted);">↔</div>
          <div id="comparar-header-v2" style="flex:1; background:rgba(46,164,79,0.1); border:1px solid rgba(46,164,79,0.3); border-radius:8px; padding:0.5rem 0.85rem; font-size:0.8rem; font-weight:600;"></div>
        </div>

        <!-- Selectores de tipo de vista -->
        <div style="display:flex; gap:0.5rem; flex-shrink:0; align-items:center; flex-wrap:wrap;">
          <span style="font-size:0.75rem; color:var(--text-muted);">Vista:</span>
          <button class="btn btn-ghost" onclick="setVistaComparacion('sidebyside')" id="vbtn-sidebyside" style="font-size:0.73rem; padding:0.3rem 0.65rem; border:1px solid var(--accent);">⬛⬛ Lado a Lado</button>
          <button class="btn btn-ghost" onclick="setVistaComparacion('diff')"       id="vbtn-diff"       style="font-size:0.73rem; padding:0.3rem 0.65rem;">📝 Diff de Texto</button>
          <button class="btn btn-ghost" onclick="setVistaComparacion('ia')"         id="vbtn-ia"         style="font-size:0.73rem; padding:0.3rem 0.65rem;">🤖 Comparar con IA</button>
          <span id="comparar-tipo-badge" style="font-size:0.73rem; color:var(--text-muted); margin-left:auto;"></span>
        </div>

        <!-- Paneles lado a lado -->
        <div id="panel-sidebyside" style="flex:1; display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; overflow:hidden; min-height:500px; height:100%;">
          <div style="border:1px solid rgba(248,81,73,0.4); border-radius:10px; overflow:hidden; display:flex; flex-direction:column;">
            <div style="background:rgba(248,81,73,0.08); padding:0.4rem 0.75rem; font-size:0.72rem; font-weight:700; color:#f85149; flex-shrink:0;">VERSIÓN ANTIGUA</div>
            <div id="visor-v1" style="flex:1; overflow:auto; background:var(--bg-secondary); height:100%;"></div>
          </div>
          <div style="border:1px solid rgba(46,164,79,0.4); border-radius:10px; overflow:hidden; display:flex; flex-direction:column;">
            <div style="background:rgba(46,164,79,0.08); padding:0.4rem 0.75rem; font-size:0.72rem; font-weight:700; color:#3fb950; flex-shrink:0;">VERSIÓN NUEVA</div>
            <div id="visor-v2" style="flex:1; overflow:auto; background:var(--bg-secondary); height:100%;"></div>
          </div>
        </div>

        <!-- Panel diff -->
        <div id="panel-diff" style="display:none; flex:1; overflow:auto; background:var(--bg-tertiary,#1a1a24); border-radius:10px; border:1px solid var(--border-subtle); padding:0.75rem; font-family:monospace; font-size:0.78rem; min-height:500px; height:100%;">
          <div id="diff-contenido"></div>
        </div>

        <!-- Panel IA -->
        <div id="panel-ia" style="display:none; flex:1; overflow:auto; background:var(--bg-secondary); border-radius:10px; border:1px solid var(--border-subtle); padding:1.25rem; font-size:0.85rem; line-height:1.6; min-height:500px; height:100%; color:var(--text-primary);">
          <div id="ia-loading" style="display:none; text-align:center; padding:5rem 0;">
            <div class="spinner" style="border: 3px solid rgba(255,255,255,0.1); border-top: 3px solid var(--accent); border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 1.25rem;"></div>
            <p style="color:var(--text-muted); font-weight: 600; font-size:0.85rem; margin-bottom: 0.25rem;">Analizando semánticamente con Gemini Flash...</p>
            <p style="color:var(--text-muted); font-size:0.72rem;">(Esto puede tardar unos segundos mientras procesa ambos entregables)</p>
          </div>
          <div id="ia-contenido" style="overflow-y:auto; height:100%; max-height: 100%;"></div>
        </div>
      </div>
    </div>

    <!-- TAB: Subir versión -->
    <div id="vtab-subir" style="display:none; overflow-y:auto;">
      <div id="seccion-nueva-version-form">
        <form id="form-nueva-version" onsubmit="enviarNuevaVersion(event)" enctype="multipart/form-data" style="display:flex; flex-direction:column; gap:0.85rem;">
          <input type="hidden" id="version-id-actividad" name="idActividad">
          <input type="hidden" id="version-id-proyecto"  name="idProyecto" value="<%= proyecto.id_proyecto %>">

          <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <div class="form-group" style="width:160px; margin-bottom:0;">
              <label class="form-label" style="font-size:0.75rem;">Número de Versión</label>
              <input type="text" id="version-numero" name="versionNumero" class="form-control" placeholder="1.0" required style="padding:0.5rem; font-size:0.82rem;">
            </div>
            <div class="form-group" style="flex:1; margin-bottom:0; min-width:200px;">
              <label class="form-label" style="font-size:0.75rem;">
                Archivo del Documento
                <span style="color:var(--text-muted); font-size:0.68rem;">(PDF, Word, Excel — guardado en BD)</span>
              </label>
              <input type="file" id="version-archivo" name="archivo" class="form-control"
                accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.md,.csv,.ppt,.pptx"
                style="padding:0.4rem 0.5rem; font-size:0.8rem;">
              <div id="archivo-preview" style="font-size:0.72rem; color:var(--text-muted); margin-top:0.3rem;"></div>
            </div>
          </div>

          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label" style="font-size:0.75rem;">
              Contenido de Texto / Código
              <span style="color:var(--text-muted); font-size:0.68rem;">(Para diff de texto — opcional si subes archivo)</span>
            </label>
            <textarea id="version-contenido-texto" name="contenidoTexto" class="form-control" rows="4"
              style="resize:vertical; padding:0.5rem; font-size:0.8rem; font-family:monospace;"
              placeholder="Pega aquí el contenido de texto para poder hacer diff de texto entre versiones..."></textarea>
          </div>

          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label" style="font-size:0.75rem;">Descripción de Cambios <span style="color:var(--red);">*</span></label>
            <textarea id="version-descripcion" name="descripcionCambio" class="form-control" rows="2"
              style="resize:vertical; padding:0.5rem; font-size:0.8rem;"
              placeholder="Detalla los cambios realizados en esta versión..." required></textarea>
          </div>

          <div style="display:flex; gap:0.75rem; justify-content:flex-end; padding-top:0.5rem; border-top:1px solid var(--border);">
            <button type="button" class="btn btn-ghost" onclick="cerrarModal('modalVersiones')" style="font-size:0.82rem;">Cancelar</button>
            <button type="submit" class="btn btn-primary" id="btn-subir-version" style="font-size:0.82rem;">⬆️ Subir y Registrar</button>
          </div>
        </form>
      </div>
      <div id="seccion-nueva-version-no-permiso" style="text-align:center; padding:2rem; display:none;">
        <div style="font-size:2rem; margin-bottom:0.5rem;">🔒</div>
        <p style="font-size:0.82rem; color:var(--text-muted);">Solo el responsable asignado, el administrador o el líder técnico pueden registrar nuevas versiones.</p>
      </div>
    </div>

  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jsdiff/5.2.0/diff.min.js"></script>
<!-- mammoth.js para convertir Word a HTML en el navegador -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<!-- SheetJS para convertir Excel a tabla HTML en el navegador -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<!-- marked.js para convertir Markdown (IA) a HTML en el navegador -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>

<script>
let actividadActual       = null;
let versionActividadActual = null;
let versionPuedeSubir     = false;
let versionesActuales     = [];
let vTabActual            = 'historial';
let vistaComparacion      = 'sidebyside';

const PROYECTO_ID          = <%= proyecto.id_proyecto %>;
const PROYECTO_GITHUB_REPO = '<%= proyecto.github_repo || "" %>';

// ─── TABS PRINCIPALES ─────────────────────────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
  localStorage.setItem('activeTab_' + PROYECTO_ID, name);
}

document.addEventListener('DOMContentLoaded', () => {
  const activeTab = localStorage.getItem('activeTab_' + PROYECTO_ID);
  if (activeTab) {
    const btn = document.getElementById('btn-tab-' + activeTab);
    if (btn) switchTab(activeTab, btn);
  }
});

function toggleEtapa(header) {
  const body  = header.nextElementSibling;
  const arrow = header.querySelector('span:first-child');
  const isOpen = body.classList.toggle('open');
  arrow.textContent = isOpen ? '▼' : '▶';
}

// ─── TABS INTERNOS DEL MODAL DE VERSIONES ────────────────────────────────────
function switchVTab(name) {
  vTabActual = name;
  ['historial','comparar','subir'].forEach(t => {
    const el  = document.getElementById('vtab-' + t);
    const btn = document.getElementById('vtab-btn-' + t);
    if (!el || !btn) return;
    const isActive = t === name;
    el.style.display  = isActive ? (t === 'historial' ? 'block' : 'flex') : 'none';
    btn.classList.toggle('active', isActive);
  });

  // El modal cambia de tamaño según la pestaña
  const box = document.getElementById('modalVersiones-box');
  if (box) {
    if (name === 'comparar') {
      box.style.height   = '96vh';
      box.style.width    = '98vw';
      box.style.maxWidth = '1600px';
    } else {
      box.style.height   = 'auto';
      box.style.width    = '680px';
      box.style.maxWidth = '96vw';
    }
  }

  if (name === 'comparar') intentarComparar();
}

// ─── MODAL REPORTAR AVANCE ────────────────────────────────────────────────────
function abrirModalReporte(idActividad, nombre, avanceActual) {
  actividadActual = idActividad;
  document.getElementById('modal-actividad-nombre').textContent = nombre;
  document.getElementById('avance-slider').value = avanceActual || 0;
  document.getElementById('avance-val').textContent = (avanceActual || 0) + '%';
  document.getElementById('reporte-comentario').value = '';
  document.getElementById('modalReporte').classList.add('open');
}

function cerrarModal(id) {
  document.getElementById(id).classList.remove('open');
}

async function enviarReporte() {
  const btn        = document.getElementById('btn-enviar-reporte');
  const porcentaje = document.getElementById('avance-slider').value;
  const comentario = document.getElementById('reporte-comentario').value.trim();
  btn.disabled = true; btn.textContent = 'Enviando...';
  try {
    const resp = await fetch('/api/reportes', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idActividad: actividadActual, porcentaje, comentario })
    });
    const data = await resp.json();
    if (data.success) { cerrarModal('modalReporte'); location.reload(); }
    else alert('Error: ' + (data.error || 'No se pudo enviar.'));
  } catch(e) { alert('Error de conexión.'); }
  finally { btn.disabled = false; btn.textContent = 'Enviar Reporte'; }
}

// ─── MODAL VERSIONES ──────────────────────────────────────────────────────────
async function abrirModalVersiones(idActividad, nombre, puedeSubir) {
  versionActividadActual = idActividad;
  versionPuedeSubir      = puedeSubir;
  versionesActuales      = [];

  document.getElementById('modal-versiones-actividad-nombre').textContent = nombre;
  document.getElementById('version-id-actividad').value = idActividad;
  document.getElementById('version-numero').value    = '';
  document.getElementById('version-descripcion').value = '';
  document.getElementById('version-archivo').value   = '';
  document.getElementById('version-contenido-texto').value = '';
  document.getElementById('comparar-visor').style.display = 'none';
  document.getElementById('comparar-seleccion-msg').style.display = 'block';

  // Mostrar / ocultar pestaña subir según permisos
  const btnSubir = document.getElementById('vtab-btn-subir');
  if (btnSubir) btnSubir.style.display = puedeSubir ? '' : 'none';

  // Sección sin permiso
  document.getElementById('seccion-nueva-version-form').style.display = puedeSubir ? '' : 'none';
  document.getElementById('seccion-nueva-version-no-permiso').style.display = puedeSubir ? 'none' : '';

  switchVTab('historial');
  // Tamaño inicial compacto (historial)
  const box = document.getElementById('modalVersiones-box');
  if (box) { box.style.width = '680px'; box.style.maxWidth = '96vw'; box.style.height = 'auto'; }
  await cargarHistorialVersiones(idActividad);
  document.getElementById('modalVersiones').classList.add('open');
}

async function cargarHistorialVersiones(idActividad) {
  const tbody = document.getElementById('versiones-tabla-body');
  const vacio = document.getElementById('versiones-vacio');
  tbody.innerHTML = '';
  vacio.style.display = 'none';
  versionesActuales = [];

  try {
    const res  = await fetch(`/api/actividades/${idActividad}/versiones`);
    const data = await res.json();

    if (data.success && data.versiones && data.versiones.length > 0) {
      versionesActuales = data.versiones;

      // Auto-incrementar número de versión en el form de subir
      if (versionPuedeSubir) {
        const ultVersion = data.versiones[0].version_numero;
        const partes = ultVersion.split('.');
        if (partes.length === 2 && !isNaN(parseInt(partes[1]))) {
          document.getElementById('version-numero').value = `${partes[0]}.${parseInt(partes[1]) + 1}`;
        } else {
          document.getElementById('version-numero').value = '1.0';
        }
      }

      data.versiones.forEach(v => {
        const mime       = v.contenido_mime || '';
        const tieneArch  = !!(v.archivo_nombre);
        const tipoIcono  = getTipoIcono(mime, v.archivo_nombre);
        const tipoLabel  = getTipoLabel(mime, v.archivo_nombre);

        const tr = document.createElement('tr');
        tr.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
        tr.innerHTML = `
          <td style="padding:0.6rem 0.4rem; text-align:center;">
            <input type="checkbox" class="diff-checkbox" value="${v.id_version}" onchange="manejarCambioCheckbox(this)">
          </td>
          <td style="padding:0.6rem 0.4rem;">
            <span class="badge badge-blue" style="font-size:0.7rem; font-weight:700;">v${v.version_numero}</span>
            ${v.commit_sha && PROYECTO_GITHUB_REPO
              ? `<a href="https://github.com/${PROYECTO_GITHUB_REPO}/commit/${v.commit_sha}" target="_blank"
                   style="margin-left:0.3rem; font-size:0.68rem; color:#38bdf8; text-decoration:none;">
                   🐙 ${v.commit_sha.substring(0,7)}</a>`
              : ''}
          </td>
          <td style="padding:0.6rem 0.4rem; color:var(--text-secondary);">${v.descripcion_cambio || 'Sin descripción'}</td>
          <td style="padding:0.6rem 0.4rem; font-size:0.8rem;">${v.autor_nombre ? v.autor_nombre.split(' ')[0] : '—'}</td>
          <td style="padding:0.6rem 0.4rem; color:var(--text-muted); font-size:0.75rem;">
            ${new Date(v.fecha_version).toLocaleDateString('es-PE', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}
          </td>
          <td style="padding:0.6rem 0.4rem; font-size:0.75rem;">
            ${tieneArch ? `<span title="${mime}">${tipoIcono} ${tipoLabel}</span>` : '<span style="color:var(--text-muted);">Texto</span>'}
          </td>
          <td style="padding:0.6rem 0.4rem; text-align:right;">
            ${tieneArch
              ? `<a href="/api/versiones/${v.id_version}/archivo" target="_blank"
                   class="btn btn-primary" style="padding:0.25rem 0.5rem; font-size:0.68rem; text-decoration:none;">
                   💾 Ver</a>`
              : '<span style="color:var(--text-muted); font-size:0.73rem;">—</span>'}
          </td>`;
        tbody.appendChild(tr);
      });
    } else {
      if (versionPuedeSubir) document.getElementById('version-numero').value = '1.0';
      vacio.style.display = 'block';
    }
  } catch (err) {
    console.error('Error al cargar versiones:', err);
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center; color:var(--red); padding:1rem;">Error al cargar el historial.</td></tr>';
  }
}

function getTipoIcono(mime, nombre) {
  if (!mime && !nombre) return '📄';
  const ext = (nombre || '').split('.').pop().toLowerCase();
  if (mime.includes('pdf') || ext === 'pdf')                          return '📕';
  if (mime.includes('word') || ['doc','docx'].includes(ext))          return '📘';
  if (mime.includes('spreadsheet') || mime.includes('excel') || ['xls','xlsx'].includes(ext)) return '📗';
  if (mime.includes('presentation') || ['ppt','pptx'].includes(ext))  return '📙';
  if (mime.includes('text') || ['txt','md','csv'].includes(ext))      return '📝';
  return '📄';
}

function getTipoLabel(mime, nombre) {
  if (!mime && !nombre) return 'Archivo';
  const ext = (nombre || '').split('.').pop().toLowerCase();
  if (mime.includes('pdf') || ext === 'pdf')                          return 'PDF';
  if (mime.includes('word') || ext === 'docx')                        return 'Word';
  if (ext === 'doc')                                                   return 'Word (doc)';
  if (mime.includes('spreadsheet') || ext === 'xlsx')                  return 'Excel';
  if (ext === 'xls')                                                   return 'Excel (xls)';
  if (mime.includes('presentation') || ['ppt','pptx'].includes(ext))  return 'PowerPoint';
  if (mime.includes('text') || ['txt','md','csv'].includes(ext))      return 'Texto';
  return ext.toUpperCase() || 'Archivo';
}

function toggleAllVersionCheckboxes(masterCb) {
  document.querySelectorAll('.diff-checkbox').forEach(cb => {
    cb.checked = masterCb.checked;
  });
  const checked = document.querySelectorAll('.diff-checkbox:checked');
  if (checked.length > 2) {
    masterCb.checked = false;
    document.querySelectorAll('.diff-checkbox').forEach(cb => cb.checked = false);
    alert('Solo puedes seleccionar un máximo de 2 versiones para comparar.');
  }
}

function manejarCambioCheckbox(cb) {
  const checked = document.querySelectorAll('.diff-checkbox:checked');
  if (checked.length > 2) {
    cb.checked = false;
    alert('Solo puedes seleccionar un máximo de 2 versiones para comparar.');
  }
}

// ─── COMPARACIÓN ──────────────────────────────────────────────────────────────
function intentarComparar() {
  const checkboxes = document.querySelectorAll('.diff-checkbox:checked');
  if (checkboxes.length !== 2) {
    document.getElementById('comparar-seleccion-msg').style.display = 'block';
    document.getElementById('comparar-visor').style.display = 'none';
    return;
  }
  const idV1 = parseInt(checkboxes[0].value);
  const idV2 = parseInt(checkboxes[1].value);
  const v1   = versionesActuales.find(v => v.id_version === idV1);
  const v2   = versionesActuales.find(v => v.id_version === idV2);
  if (!v1 || !v2) return;

  const antigua = new Date(v1.fecha_version) < new Date(v2.fecha_version) ? v1 : v2;
  const nueva   = antigua === v1 ? v2 : v1;

  document.getElementById('comparar-header-v1').textContent = `📌 v${antigua.version_numero} — ${antigua.descripcion_cambio || 'Sin desc.'}`;
  document.getElementById('comparar-header-v2').textContent = `✅ v${nueva.version_numero} — ${nueva.descripcion_cambio || 'Sin desc.'}`;

  document.getElementById('comparar-seleccion-msg').style.display = 'none';
  document.getElementById('comparar-visor').style.display = 'flex';

  // Vaciar contenido de análisis IA previo
  const iaContenido = document.getElementById('ia-contenido');
  if (iaContenido) iaContenido.innerHTML = '';

  cargarVisorDocumento('visor-v1', antigua);
  cargarVisorDocumento('visor-v2', nueva);
  generarDiffTexto(antigua, nueva);
  setVistaComparacion('sidebyside');

  // Mostrar tipo detectado
  const mime = antigua.contenido_mime || nueva.contenido_mime || '';
  const nombre = antigua.archivo_nombre || nueva.archivo_nombre || '';
  document.getElementById('comparar-tipo-badge').textContent =
    `Tipo detectado: ${getTipoIcono(mime, nombre)} ${getTipoLabel(mime, nombre)}`;
}

async function cargarVisorDocumento(panelId, version) {
  const panel = document.getElementById(panelId);
  panel.innerHTML = '<div style="padding:1rem; color:var(--text-muted); font-size:0.8rem;">Cargando...</div>';

  const mime   = version.contenido_mime || '';
  const nombre = version.archivo_nombre || '';
  const ext    = nombre.split('.').pop().toLowerCase();

  // ── PDF ──────────────────────────────────────────────────────────────────────
  if (mime.includes('pdf') || ext === 'pdf') {
    panel.innerHTML = `
      <iframe src="/api/versiones/${version.id_version}/archivo"
        style="width:100%; height:100%; min-height:600px; border:none; display:block;"
        title="v${version.version_numero}">
      </iframe>`;
    return;
  }

  // ── Word (.docx) ─────────────────────────────────────────────────────────────
  if (mime.includes('word') || ext === 'docx') {
    try {
      const resp   = await fetch(`/api/versiones/${version.id_version}/archivo`);
      const buffer = await resp.arrayBuffer();
      const result = await mammoth.convertToHtml({ arrayBuffer: buffer });
      panel.innerHTML = `<div style="padding:1rem; font-size:0.82rem; line-height:1.6; color:var(--text-primary);">
        ${result.value}
      </div>`;
    } catch (e) {
      panel.innerHTML = `<div style="padding:1rem; color:var(--red); font-size:0.8rem;">
        ❌ No se pudo renderizar el Word: ${e.message}</div>`;
    }
    return;
  }

  // ── Excel (.xlsx) ─────────────────────────────────────────────────────────────
  if (mime.includes('spreadsheet') || mime.includes('excel') || ['xls','xlsx'].includes(ext)) {
    try {
      const resp   = await fetch(`/api/versiones/${version.id_version}/archivo`);
      const buffer = await resp.arrayBuffer();
      const wb     = XLSX.read(buffer, { type: 'array' });
      const ws     = wb.Sheets[wb.SheetNames[0]];
      const html   = XLSX.utils.sheet_to_html(ws, { editable: false });
      panel.innerHTML = `<div style="padding:0.5rem; overflow:auto;">
        <style>
          #${panelId} table { border-collapse:collapse; font-size:0.75rem; width:100%; }
          #${panelId} td, #${panelId} th { border:1px solid var(--border); padding:0.25rem 0.5rem; }
          #${panelId} tr:first-child td, #${panelId} th { background:var(--bg-tertiary); font-weight:600; }
        </style>
        ${html}
      </div>`;
    } catch (e) {
      panel.innerHTML = `<div style="padding:1rem; color:var(--red); font-size:0.8rem;">
        ❌ No se pudo renderizar el Excel: ${e.message}</div>`;
    }
    return;
  }

  // ── Texto / código (fallback) ─────────────────────────────────────────────────
  if (version.contenido_texto) {
    panel.innerHTML = `<pre style="padding:1rem; font-size:0.78rem; margin:0; white-space:pre-wrap; color:var(--text-secondary); overflow:auto;">${
      version.contenido_texto.replace(/</g,'&lt;').replace(/>/g,'&gt;')
    }</pre>`;
    return;
  }

  // ── Archivo descargable sin visor ─────────────────────────────────────────────
  if (version.archivo_nombre) {
    panel.innerHTML = `<div style="padding:2rem; text-align:center; color:var(--text-muted);">
      <div style="font-size:2.5rem; margin-bottom:0.75rem;">${getTipoIcono(mime, nombre)}</div>
      <p style="font-size:0.82rem; margin-bottom:1rem;">Vista previa no disponible para este tipo de archivo.</p>
      <a href="/api/versiones/${version.id_version}/archivo" download="${nombre}" 
         class="btn btn-primary" style="font-size:0.8rem; text-decoration:none;">
        💾 Descargar v${version.version_numero}
      </a>
    </div>`;
    return;
  }

  panel.innerHTML = '<div style="padding:1rem; color:var(--text-muted); font-size:0.8rem; text-align:center;">Sin contenido disponible.</div>';
}

function generarDiffTexto(antigua, nueva) {
  const text1 = antigua.contenido_texto || '';
  const text2 = nueva.contenido_texto   || '';
  const diffEl = document.getElementById('diff-contenido');

  if (!text1.trim() && !text2.trim()) {
    diffEl.innerHTML = '<div style="color:var(--text-muted); text-align:center; padding:2rem; font-size:0.82rem;">ℹ️ Ninguna versión tiene contenido de texto para comparar.<br>El diff de texto solo funciona cuando se pega contenido en el campo de texto al subir la versión.</div>';
    return;
  }

  const diff = Diff.diffLines(text1, text2);
  const pre  = document.createElement('pre');
  pre.style.margin = '0';

  const header = document.createElement('div');
  header.style.cssText = 'border-bottom:1px solid var(--border-subtle);padding-bottom:0.5rem;margin-bottom:0.5rem;font-weight:bold;font-size:0.8rem;color:var(--text-primary);';
  header.innerHTML = `Comparando <span style="color:#f85149;">v${antigua.version_numero}</span> → <span style="color:#3fb950;">v${nueva.version_numero}</span>`;
  pre.appendChild(header);

  let totalAdd = 0, totalDel = 0;
  diff.forEach(part => {
    let val = part.value;
    if (val.endsWith('\n')) val = val.slice(0, -1);
    val.split('\n').forEach(line => {
      const span = document.createElement('span');
      span.style.display = 'block';
      span.style.padding  = '0.1rem 0.5rem';
      if (part.added) {
        span.style.background = 'rgba(46,164,79,0.15)';
        span.style.color      = '#3fb950';
        span.style.borderLeft = '3px solid #2ea44f';
        span.textContent = `+ ${line}`;
        totalAdd++;
      } else if (part.removed) {
        span.style.background = 'rgba(248,81,73,0.15)';
        span.style.color      = '#f85149';
        span.style.borderLeft = '3px solid #f85149';
        span.textContent = `- ${line}`;
        totalDel++;
      } else {
        span.style.color   = 'var(--text-muted)';
        span.style.opacity = '0.65';
        span.textContent   = `  ${line}`;
      }
      pre.appendChild(span);
    });
  });

  const summary = document.createElement('div');
  summary.style.cssText = 'margin-top:0.75rem; padding-top:0.5rem; border-top:1px solid var(--border-subtle); font-size:0.75rem; color:var(--text-muted);';
  summary.innerHTML = `<span style="color:#3fb950;">+${totalAdd} líneas agregadas</span> &nbsp; <span style="color:#f85149;">-${totalDel} líneas eliminadas</span>`;
  pre.appendChild(summary);

  diffEl.innerHTML = '';
  diffEl.appendChild(pre);
}

function setVistaComparacion(vista) {
  vistaComparacion = vista;
  const sbs  = document.getElementById('panel-sidebyside');
  const diff = document.getElementById('panel-diff');
  const ia   = document.getElementById('panel-ia');

  const btnS = document.getElementById('vbtn-sidebyside');
  const btnD = document.getElementById('vbtn-diff');
  const btnI = document.getElementById('vbtn-ia');

  if (!sbs || !diff || !ia) return;

  sbs.style.display  = vista === 'sidebyside' ? 'grid' : 'none';
  diff.style.display = vista === 'diff' ? 'block' : 'none';
  ia.style.display   = vista === 'ia' ? 'block' : 'none';

  if (btnS) btnS.style.border = vista === 'sidebyside' ? '1px solid var(--accent)' : '';
  if (btnD) btnD.style.border = vista === 'diff' ? '1px solid var(--accent)' : '';
  if (btnI) btnI.style.border = vista === 'ia' ? '1px solid var(--accent)' : '';

  if (vista === 'ia') {
    ejecutarComparacionIA();
  }
}

async function ejecutarComparacionIA() {
  const contenidoDiv = document.getElementById('ia-contenido');
  const loadingDiv   = document.getElementById('ia-loading');
  if (!contenidoDiv || !loadingDiv) return;

  // Si ya tiene contenido, no volvemos a llamar (caché local del modal)
  if (contenidoDiv.innerHTML.trim() !== '') return;

  const checkboxes = document.querySelectorAll('.diff-checkbox:checked');
  if (checkboxes.length !== 2) {
    contenidoDiv.innerHTML = '<div style="padding:2rem; text-align:center; color:var(--text-muted);">Selecciona exactamente 2 versiones para analizar con IA.</div>';
    return;
  }

  const idV1 = parseInt(checkboxes[0].value);
  const idV2 = parseInt(checkboxes[1].value);

  loadingDiv.style.display = 'block';
  contenidoDiv.style.display = 'none';

  try {
    const res = await fetch('/api/versiones/comparar-ia', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idV1, idV2 })
    });
    const data = await res.json();

    if (data.success && data.analysis) {
      contenidoDiv.innerHTML = marked.parse(data.analysis);
    } else {
      contenidoDiv.innerHTML = `
        <div style="padding:2rem; text-align:center; color:var(--red);">
          <span style="font-size:2rem;">⚠️</span>
          <p style="margin-top:0.75rem; font-weight:600; font-size:0.88rem;">No se pudo realizar el análisis con IA</p>
          <p style="font-size:0.8rem; color:var(--text-muted); max-width:500px; margin:0.5rem auto 0; line-height:1.5;">
            ${data.error || 'Ocurrió un error inesperado al procesar la solicitud.'}
          </p>
        </div>`;
    }
  } catch (err) {
    console.error('Error llamando a la comparación con IA:', err);
    contenidoDiv.innerHTML = `
      <div style="padding:2rem; text-align:center; color:var(--red);">
        <span style="font-size:2rem;">❌</span>
        <p style="margin-top:0.75rem; font-weight:600;">Error de conexión</p>
        <p style="font-size:0.8rem; color:var(--text-muted);">No se pudo conectar con el servidor.</p>
      </div>`;
  } finally {
    loadingDiv.style.display = 'none';
    contenidoDiv.style.display = 'block';
  }
}

// ─── SUBIR NUEVA VERSIÓN ──────────────────────────────────────────────────────
document.getElementById('version-archivo').addEventListener('change', function() {
  const file    = this.files[0];
  const preview = document.getElementById('archivo-preview');
  if (file) {
    const mb = (file.size / 1024 / 1024).toFixed(2);
    preview.innerHTML = `📎 <strong>${file.name}</strong> · ${mb} MB · <span style="color:var(--accent);">${file.type || 'tipo desconocido'}</span>`;
  } else {
    preview.innerHTML = '';
  }
});

async function enviarNuevaVersion(e) {
  e.preventDefault();
  const btn     = document.getElementById('btn-subir-version');
  const form    = document.getElementById('form-nueva-version');
  const archivo = document.getElementById('version-archivo').files[0];
  const texto   = document.getElementById('version-contenido-texto').value.trim();

  if (!archivo && !texto) {
    alert('Debes adjuntar un archivo o rellenar el contenido de texto para registrar la versión.');
    return;
  }

  const formData = new FormData(form);
  btn.disabled    = true;
  btn.textContent = 'Guardando...';

  try {
    const res  = await fetch('/api/versiones', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.success) {
      await cargarHistorialVersiones(versionActividadActual);
      document.getElementById('version-descripcion').value = '';
      document.getElementById('version-archivo').value     = '';
      document.getElementById('version-contenido-texto').value = '';
      document.getElementById('archivo-preview').innerHTML = '';
      switchVTab('historial');
      alert('✅ Versión registrada y guardada en la base de datos.');
    } else {
      alert('Error: ' + (data.error || 'No se pudo subir la versión.'));
    }
  } catch (err) {
    alert('Error de conexión.');
  } finally {
    btn.disabled    = false;
    btn.textContent = '⬆️ Subir y Registrar';
  }
}

// ─── CERRAR MODALES ───────────────────────────────────────────────────────────
document.getElementById('modalReporte').addEventListener('click', function(e) {
  if (e.target === this) cerrarModal('modalReporte');
});
document.getElementById('modalVersiones').addEventListener('click', function(e) {
  if (e.target === this) cerrarModal('modalVersiones');
});
</script>


