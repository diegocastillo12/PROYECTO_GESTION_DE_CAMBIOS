<%
  /**
   * sidebar.ejs — Menú lateral adaptativo según el rol del usuario en sesión
   * Soporta: Administrador, Solicitante, y todos los roles del equipo técnico
   */
  const ROLES = locals.roles || {};
  const u = locals.user || {};
  const rol = u.rol || '';
  const path = locals.currentPath || '';

  const isAdministrador  = rol === ROLES.ADMINISTRADOR;
  const isSolicitante    = rol === ROLES.SOLICITANTE;
  const isEquipo         = !isAdministrador && !isSolicitante;

  const canCreateTicket  = [ROLES.SOLICITANTE, ROLES.DIRECTOR, ROLES.GESTOR_CONFIGURACION, ROLES.LIDER_TECNICO].includes(rol);
  const canViewAnalysis  = [ROLES.LIDER_TECNICO, ROLES.GESTOR_CONFIGURACION, ROLES.DIRECTOR].includes(rol);
  const canViewCCB       = rol === ROLES.CCB;
  const canViewDev       = [ROLES.DESARROLLADOR, ROLES.LIDER_TECNICO].includes(rol);
  const canViewQA        = [ROLES.TESTER, ROLES.LIDER_TECNICO].includes(rol);
%>

<!-- Overlay para movil -->
<div id="sidebar-overlay"></div>

<aside id="sidebar" class="sidebar">

  <!-- Logo -->
  <div class="sidebar-logo">
    <div class="sidebar-logo-icon">⚙️</div>
    <div class="sidebar-logo-text">
      <span class="sidebar-logo-title">GestioCambios</span>
      <span class="sidebar-logo-sub">G04 · SCM System</span>
    </div>
  </div>

  <!-- Perfil del usuario -->
  <% if (u && u.nombre) { %>
  <div class="sidebar-profile" style="display:flex; align-items:center; justify-content:space-between; width:100%; padding-right: 0.5rem;">
    <div style="display:flex; align-items:center; gap:0.75rem;">
      <div class="sidebar-avatar"><%= u.nombre.slice(0,2).toUpperCase() %></div>
      <div class="sidebar-profile-info">
        <div class="sidebar-profile-name"><%= u.nombre %></div>
        <div class="sidebar-profile-role"><%= u.rol %></div>
      </div>
    </div>
    <button onclick="abrirModalGitHub()" title="Configuración de GitHub" style="background:transparent; border:none; color:var(--text-muted, #94a3b8); cursor:pointer; font-size:1.15rem; padding:0.25rem; display:flex; align-items:center; justify-content:center; transition: color 0.2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='var(--text-muted, #94a3b8)'">⚙️</button>
  </div>
  <% } %>

  <!-- Navegación -->
  <nav class="sidebar-nav">

    <!-- ═══ ADMINISTRADOR ═══ -->
    <% if (isAdministrador) { %>
    <div class="nav-section">
      <div class="nav-section-title">Panel Admin</div>
      <a href="/admin" class="nav-item<%= path === '/admin' ? ' active' : '' %>">
        <span class="nav-item-icon">🏠</span>
        <span>Inicio</span>
      </a>
      <a href="/admin/proyectos" class="nav-item<%= path.startsWith('/admin/proyectos') ? ' active' : '' %>">
        <span class="nav-item-icon">📁</span>
        <span>Proyectos</span>
      </a>
      <a href="/admin/usuarios" class="nav-item<%= path === '/admin/usuarios' ? ' active' : '' %>">
        <span class="nav-item-icon">👥</span>
        <span>Usuarios</span>
      </a>
      <a href="/admin/metodologias" class="nav-item<%= path === '/admin/metodologias' ? ' active' : '' %>">
        <span class="nav-item-icon">📐</span>
        <span>Metodologías</span>
      </a>
    </div>
    <div class="nav-section">
      <div class="nav-section-title">Tickets</div>
      <a href="/tickets" class="nav-item<%= path === '/tickets' ? ' active' : '' %>">
        <span class="nav-item-icon">🎫</span>
        <span>Todos los Tickets</span>
      </a>
    </div>
    <% } %>

    <!-- ═══ SOLICITANTE ═══ -->
    <% if (isSolicitante) { %>
    <div class="nav-section">
      <div class="nav-section-title">Mis Proyectos</div>
      <a href="/cartera" class="nav-item<%= path === '/cartera' ? ' active' : '' %>">
        <span class="nav-item-icon">💼</span>
        <span>Mi Cartera</span>
      </a>
    </div>
    <div class="nav-section">
      <div class="nav-section-title">Solicitudes</div>
      <a href="/tickets" class="nav-item<%= path === '/tickets' ? ' active' : '' %>">
        <span class="nav-item-icon">🎫</span>
        <span>Mis Tickets</span>
      </a>
      <a href="/tickets/nuevo" class="nav-item<%= path === '/tickets/nuevo' ? ' active' : '' %>">
        <span class="nav-item-icon">➕</span>
        <span>Nueva Solicitud</span>
      </a>
    </div>
    <% } %>

    <!-- ═══ EQUIPO TÉCNICO ═══ -->
    <% if (isEquipo) { %>
    <div class="nav-section">
      <div class="nav-section-title">General</div>
      <a href="/dashboard" class="nav-item<%= path === '/dashboard' ? ' active' : '' %>">
        <span class="nav-item-icon">📊</span>
        <span>Dashboard</span>
      </a>
      <a href="/cartera" class="nav-item<%= path === '/cartera' ? ' active' : '' %>">
        <span class="nav-item-icon">💼</span>
        <span>Mis Proyectos</span>
      </a>
      <% if (canCreateTicket) { %>
      <a href="/tickets/nuevo" class="nav-item<%= path === '/tickets/nuevo' ? ' active' : '' %>">
        <span class="nav-item-icon">➕</span>
        <span>Nuevo Ticket</span>
      </a>
      <% } %>
    </div>

    <div class="nav-section">
      <div class="nav-section-title">Mi Bandeja</div>

      <% if (canViewAnalysis) { %>
      <a href="/tickets?estado=Solicitado" class="nav-item">
        <span class="nav-item-icon">📋</span>
        <span>Solicitados</span>
      </a>
      <a href="/tickets?estado=En+An%C3%A1lisis" class="nav-item">
        <span class="nav-item-icon">🔍</span>
        <span>En Análisis</span>
      </a>
      <% } %>

      <% if (rol === ROLES.DIRECTOR || canViewCCB) { %>
      <a href="/tickets?estado=Pendiente+de+Aprobaci%C3%B3n" class="nav-item">
        <span class="nav-item-icon">✅</span>
        <span>Para Aprobación</span>
      </a>
      <% } %>

      <% if (canViewDev) { %>
      <a href="/tickets?estado=En+Desarrollo" class="nav-item">
        <span class="nav-item-icon">💻</span>
        <span>En Desarrollo</span>
      </a>
      <% } %>

      <% if (canViewQA) { %>
      <a href="/tickets?estado=En+Pruebas+QA" class="nav-item">
        <span class="nav-item-icon">🧪</span>
        <span>En Pruebas QA</span>
      </a>
      <% } %>

      <a href="/tickets" class="nav-item">
        <span class="nav-item-icon">🎫</span>
        <span>Todos los Tickets</span>
      </a>
    </div>
    <% } %>

  </nav>

  <!-- Footer sidebar -->
  <div class="sidebar-footer" style="display:flex; flex-direction:column; gap:0.4rem;">
    <button id="theme-toggle-btn" class="nav-item btn-ghost w-full" style="border:none; cursor:pointer; text-align:left;">
      <span class="nav-item-icon" id="theme-toggle-icon">☀️</span>
      <span id="theme-toggle-text">Modo Claro</span>
    </button>
    <button id="logout-btn" class="nav-item btn-ghost w-full" style="border:none; cursor:pointer; text-align:left;">
      <span class="nav-item-icon">🚪</span>
      <span>Cerrar Sesión</span>
    </button>
  </div>

</aside>

<!-- Modal: Configuración Global de GitHub -->
<div class="modal-overlay" id="modalGitHub" style="display:none; position:fixed; inset:0; z-index:999; background:rgba(0,0,0,0.65); backdrop-filter:blur(4px); align-items:center; justify-content:center;">
  <div class="modal-box" style="background:var(--bg-secondary, #1e1e2f); border:1px solid var(--border-subtle, #2d2d3f); border-radius:12px; width:450px; max-width:90%; padding:1.5rem; position:relative; box-shadow: 0 10px 25px rgba(0,0,0,0.5);">
    <button onclick="cerrarModalGitHub()" style="position:absolute; top:0.75rem; right:0.75rem; background:transparent; border:none; color:var(--text-muted); font-size:1.1rem; cursor:pointer;">✕</button>
    
    <div style="font-size:1.15rem; font-weight:700; color:var(--text-primary, #ffffff); margin-bottom:0.5rem; display:flex; align-items:center; gap:0.5rem;">
      <span>🐙 Conectar con GitHub</span>
    </div>
    <p style="font-size:0.78rem; color:var(--text-muted, #94a3b8); margin-bottom:1.25rem; line-height:1.4;">
      Vincula tu cuenta usando un <strong>Personal Access Token (PAT)</strong> para habilitar el versionado real y automático de tus entregables en repositorios de GitHub.
    </p>

    <!-- Estado de la Conexión -->
    <div id="github-estado-container" style="background:rgba(255,255,255,0.03); border:1px solid var(--border-subtle, #2d2d3f); padding:0.75rem; border-radius:8px; margin-bottom:1.25rem; display:flex; align-items:center; justify-content:space-between;">
      <span style="font-size:0.8rem; color:var(--text-secondary);">Estado de Conexión:</span>
      <span id="github-estado-badge" class="badge badge-slate" style="font-size:0.72rem; font-weight:700;">Verificando...</span>
    </div>

    <!-- Formulario de Token -->
    <div class="form-group" style="margin-bottom:1.25rem;">
      <label class="form-label" style="font-size:0.75rem; margin-bottom:0.4rem; display:block;">GitHub Personal Access Token (PAT)</label>
      <input type="password" id="github-pat-input" class="form-input" placeholder="ghp_..." style="width:100%; padding:0.5rem; font-size:0.82rem; background:var(--bg-primary, #121214); border:1px solid var(--border-subtle, #2d2d3f); border-radius:6px; color:#ffffff;">
      <small style="display:block; font-size:0.68rem; color:var(--text-muted); margin-top:0.35rem;">
        * Requiere permisos de escritura en repositorios (<code>repo</code>). Tu token se almacena cifrado en la base de datos.
      </small>
    </div>

    <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
      <button class="btn btn-ghost" onclick="cerrarModalGitHub()" style="padding:0.45rem 1rem; font-size:0.8rem;">Cerrar</button>
      <button class="btn btn-primary" id="btn-guardar-github" onclick="guardarGitHubToken()" style="padding:0.45rem 1rem; font-size:0.8rem; background:var(--accent, #6366f1); color:#ffffff; border:none; border-radius:6px; font-weight:600; cursor:pointer;">Guardar Token</button>
    </div>
  </div>
</div>

<script>
function abrirModalGitHub() {
  document.getElementById('modalGitHub').style.display = 'flex';
  verificarEstadoGitHub();
}

function cerrarModalGitHub() {
  document.getElementById('modalGitHub').style.display = 'none';
}

async function verificarEstadoGitHub() {
  const badge = document.getElementById('github-estado-badge');
  badge.className = 'badge badge-slate';
  badge.textContent = 'Verificando...';
  
  try {
    const res = await fetch('/api/usuario/github-status');
    const data = await res.json();
    
    if (data.success && data.conectado) {
      badge.className = 'badge badge-teal';
      badge.style.background = '#0d9488';
      badge.style.color = '#ffffff';
      badge.textContent = `🟢 Conectado (${data.username})`;
      document.getElementById('github-pat-input').placeholder = '••••••••••••••••••••••••••••';
    } else {
      badge.className = 'badge badge-red';
      badge.style.background = '#dc2626';
      badge.style.color = '#ffffff';
      badge.textContent = '🔴 Desconectado';
      document.getElementById('github-pat-input').placeholder = 'ghp_...';
    }
  } catch (err) {
    badge.textContent = 'Error de conexión';
  }
}

async function guardarGitHubToken() {
  const btn = document.getElementById('btn-guardar-github');
  const token = document.getElementById('github-pat-input').value.trim();
  
  btn.disabled = true;
  btn.textContent = 'Guardando...';
  
  try {
    const res = await fetch('/api/usuario/github-token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token })
    });
    const data = await res.json();
    
    if (data.success) {
      alert('Configuración de GitHub actualizada correctamente.');
      document.getElementById('github-pat-input').value = '';
      await verificarEstadoGitHub();
    } else {
      alert('Error: ' + (data.error || 'No se pudo guardar el token.'));
    }
  } catch (err) {
    alert('Error al conectar con el servidor.');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Guardar Token';
  }
}

// Cargar estado inicial al cargar sidebar
document.addEventListener('DOMContentLoaded', () => {
  // Solo verificar si hay sesión activa de usuario
  <% if (u && u.nombre) { %>
    verificarEstadoGitHub();
  <% } %>
});

// Cerrar con click fuera
document.getElementById('modalGitHub').addEventListener('click', function(e) {
  if (e.target === this) cerrarModalGitHub();
});
</script>
